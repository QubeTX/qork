<!--
  qork Corporate Edition (perUser MSI).

  This template ships alongside `wix/main.wxs` (the Global / perMachine MSI).
  Built by `.github/workflows/windows-installers.yml` after `release.yml`
  finishes publishing the GitHub Release, then uploaded as
  `qork-x86_64-pc-windows-msvc-corporate.msi`.

  Differences vs main.wxs (intentional — do not converge):
    - InstallScope="perUser" on the Package element. Sufficient on WiX 3.11+
        to install without UAC on machines where the user has no admin rights
        but still has write access to %LocalAppData%. (See the v3.15.0-era
        note in the sibling tr300 project: WiX 3.11 candle rejects
        ALLUSERS Value="" with CNDL0006, so we rely on InstallScope alone.)
    - UpgradeCode is a DIFFERENT GUID from the Global edition.
        Same UpgradeCode across editions would confuse Windows Installer
        and break upgrades in both directions. A user can have both
        editions installed simultaneously (Add/Remove Programs shows
        two entries); PATH order decides which `qork` wins.
    - Install location: %LocalAppData%\Programs\qork\bin\qork.exe
        instead of %ProgramFiles%\qork\bin\qork.exe.
    - PATH entry: user PATH (HKCU\Environment\Path) instead of
        system PATH (HKLM\...\Session Manager\Environment\Path).
    - Product Name: "qork (Corporate Edition)" — distinct ARP entry.

  qork installs ONLY the single binary on PATH plus the install-source
  registry marker. No shell alias, no auto-run, no migrate-cleanup
  custom actions (those exist in the tr300 source this was adapted from
  and were deliberately stripped here).

  If install paths in this file change, update
  `src/update.rs::classify_install_path()` / `detect_install_origin()` in
  lockstep — that logic matches on the install path / registry marker to
  choose which MSI to fetch during `qork update`.
-->

<!--
  The "cargo wix" subcommand provides a variety of predefined variables available
  for customization of this template. The values for each variable are set at
  installer creation time. The following variables are available:

  TargetTriple      = The rustc target triple name.
  TargetEnv         = The rustc target environment. This is typically either
                      "msvc" or "gnu" depending on the toolchain downloaded and
                      installed.
  TargetVendor      = The rustc target vendor. This is typically "pc", but Rust
                      does support other vendors, like "uwp".
  CargoTargetBinDir = The complete path to the directory containing the
                      binaries (exes) to include. The default would be
                      "target\release\". If an explicit rustc target triple is
                      used, i.e. cross-compiling, then the default path would
                      be "target\<CARGO_TARGET>\<CARGO_PROFILE>",
                      where "<CARGO_TARGET>" is replaced with the "CargoTarget"
                      variable value and "<CARGO_PROFILE>" is replaced with the
                      value from the "CargoProfile" variable. This can also
                      be overridden manually with the "target-bin-dir" flag.
  CargoTargetDir    = The path to the directory for the build artifacts, i.e.
                      "target".
  CargoProfile      = The cargo profile used to build the binaries
                      (usually "debug" or "release").
  Version           = The version for the installer. The default is the
                      "Major.Minor.Fix" semantic versioning number of the Rust
                      package.
-->

<Wix xmlns='http://schemas.microsoft.com/wix/2006/wi'>

    <Product
        Id='*'
        Name='qork (Corporate Edition)'
        UpgradeCode='82F33266-44A5-4F00-96A0-AC3E57B81683'
        Manufacturer='Emmett S'
        Language='1033'
        Codepage='1252'
        Version='$(var.Version)'>

        <Package Id='*'
            Keywords='Installer'
            Description='Shorten URLs from your terminal — the qork.me command-line client (Corporate Edition, per-user install)'
            Manufacturer='Emmett S'
            InstallerVersion='450'
            Languages='1033'
            Compressed='yes'
            InstallScope='perUser'
            SummaryCodepage='1252'
            />

        <!-- perUser scope: InstallScope='perUser' on the Package element above
             is sufficient on WiX 3.11+ to make this a per-user install with
             no UAC. We deliberately do NOT declare ALLUSERS or
             MSIINSTALLPERUSER Properties explicitly — WiX 3.11 candle rejects
             `<Property Id='ALLUSERS' Value=''/>` with CNDL0006 ("Property/@Value
             attribute's value cannot be an empty string"), and
             MSIINSTALLPERUSER is redundant when InstallScope='perUser' is set.
             The WiX 3 docs say InstallScope='perUser' is equivalent to setting
             ALLUSERS='' / not setting ALLUSERS at all. -->

        <MajorUpgrade
            Schedule='afterInstallInitialize'
            DowngradeErrorMessage='A newer version of [ProductName] is already installed. Setup will now exit.'/>

        <Media Id='1' Cabinet='media1.cab' EmbedCab='yes' DiskPrompt='CD-ROM #1'/>
        <Property Id='DiskPrompt' Value='qork (Corporate Edition) Installation'/>

        <Directory Id='TARGETDIR' Name='SourceDir'>
            <Directory Id='LocalAppDataFolder'>
                <Directory Id='ProgramsFolder' Name='Programs'>
                    <Directory Id='APPLICATIONFOLDER' Name='qork'>
                        <!-- Install-source marker. qork update reads this from
                             HKCU and picks the matching installer to download for
                             in-place upgrades. Value must match the literal
                             `msi-corporate` arm in src/update.rs. -->
                        <Component Id='InstallSourceMarker' Guid='9065F8A9-DD0D-42E6-8F69-0AC69E44F6C5'>
                            <RegistryValue
                                Root='HKCU'
                                Key='Software\Qork'
                                Name='InstallSource'
                                Type='string'
                                Value='msi-corporate'
                                KeyPath='yes'/>
                        </Component>
                        <Directory Id='Bin' Name='bin'>
                            <Component Id='Path' Guid='6A044691-9643-4155-BABD-79EEA553A8D5' KeyPath='yes'>
                                <!-- User PATH (HKCU\Environment\Path), not system PATH. -->
                                <Environment
                                    Id='PATH'
                                    Name='PATH'
                                    Value='[Bin]'
                                    Permanent='no'
                                    Part='last'
                                    Action='set'
                                    System='no'/>
                            </Component>
                            <Component Id='binary0' Guid='*'>
                                <File
                                    Id='exe0'
                                    Name='qork.exe'
                                    DiskId='1'
                                    Source='$(var.CargoTargetBinDir)\qork.exe'
                                    KeyPath='yes'/>
                            </Component>
                        </Directory>
                    </Directory>
                </Directory>
            </Directory>
        </Directory>

        <Feature
            Id='Binaries'
            Title='Application'
            Description='Installs the qork binary (Corporate Edition, per-user).'
            Level='1'
            ConfigurableDirectory='APPLICATIONFOLDER'
            AllowAdvertise='no'
            Display='expand'
            Absent='disallow'>

            <ComponentRef Id='binary0'/>
            <ComponentRef Id='InstallSourceMarker'/>

            <Feature
                Id='Environment'
                Title='PATH Environment Variable'
                Description='Add the install location of [ProductName] to your user PATH so the binary is callable from any terminal.'
                Level='1'
                Absent='allow'>
                <ComponentRef Id='Path'/>
            </Feature>
        </Feature>

        <SetProperty Id='ARPINSTALLLOCATION' Value='[APPLICATIONFOLDER]' After='CostFinalize'/>

        <Property Id='ARPHELPLINK' Value='https://qork.me/install'/>

        <UI>
            <UIRef Id='WixUI_FeatureTree'/>

            <Publish Dialog='WelcomeDlg' Control='Next' Event='NewDialog' Value='CustomizeDlg' Order='99'>1</Publish>
            <Publish Dialog='CustomizeDlg' Control='Back' Event='NewDialog' Value='WelcomeDlg' Order='99'>1</Publish>

        </UI>

    </Product>

</Wix>
